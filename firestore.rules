// firestore.rules — Bitácora Ecofit V6
// Desplegar con: firebase deploy --only firestore:rules
//
// Modelo de seguridad:
//   - Solo usuarios autenticados con Firebase Auth pueden leer/escribir
//   - El perfil del usuario en /users/{uid} determina su rol
//   - Admins pueden hacer todo
//   - Líderes pueden leer y escribir proyectos, pero no crear/eliminar usuarios
//   - Apoyo puede leer proyectos y escribir solo los proyectos asignados
//   - /kv y /config: solo admins escriben, todos los autenticados leen

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────
    function isAuth()  { return request.auth != null; }
    function uid()     { return request.auth.uid; }

    // Leer el perfil del usuario actual desde Firestore
    function myProfile() {
      return get(/databases/$(database)/documents/users/$(uid())).data;
    }

    function myRol() {
      return myProfile().rol;
    }

    function isAdmin()  { return isAuth() && myRol() == 'admin'; }
    function isLider()  { return isAuth() && (myRol() == 'lider' || myRol() == 'admin'); }
    function isActive() { return isAuth() && myProfile().activo == true; }

    // ── Máquina de estados — debe mantenerse sincronizada a mano con
    //    TRANSITIONS en js/auth.js. Solo se aplica a lider/apoyo: admin
    //    conserva su override total (válvula de escape ante casos atípicos).
    function transitionMap() {
      return {
        'borrador':           {'admin': ['en_progreso','cancelado'], 'lider': ['en_progreso'], 'apoyo': []},
        'en_progreso':        {'admin': ['pendiente_revision','cancelado'], 'lider': ['pendiente_revision'], 'apoyo': ['pendiente_revision']},
        'pendiente_revision': {'admin': ['observado','comisionado','cerrado','en_progreso'], 'lider': [], 'apoyo': []},
        'observado':          {'admin': ['cerrado','cancelado'], 'lider': ['en_progreso'], 'apoyo': []},
        'comisionado':        {'admin': ['en_garantia','cerrado'], 'lider': ['en_garantia'], 'apoyo': []},
        'en_garantia':        {'admin': ['fuera_garantia','cerrado'], 'lider': [], 'apoyo': []},
        'fuera_garantia':     {'admin': ['cerrado'], 'lider': [], 'apoyo': []},
        'cerrado':            {'admin': [], 'lider': [], 'apoyo': []},
        'cancelado':          {'admin': ['borrador'], 'lider': [], 'apoyo': []},
      };
    }
    function isValidTransition(desde, hasta, rol) {
      let m = transitionMap();
      return desde in m && rol in m[desde] && hasta in m[desde][rol];
    }

    // ── Proyectos ─────────────────────────────────────────────────────────────
    match /projects/{projectId} {
      // Cualquier usuario activo puede leer proyectos
      allow read: if isActive();

      // Admin y líder pueden crear proyectos
      allow create: if isLider() && isActive();

      function tocaEstado() {
        return request.resource.data.diff(resource.data).affectedKeys().hasAny(['estado']);
      }
      function isAsignado() {
        return myRol() == 'apoyo' && (
          resource.data.tecnicoLiderId == uid() ||
          uid() in resource.data.tecnicosApoyo
        );
      }

      // Admin: override total (incluye cambios de estado fuera de la máquina de estados).
      // Líder/apoyo: si el write toca 'estado', debe ser una transición válida para su
      // rol (replica TRANSITIONS de js/auth.js); si no toca 'estado', aplican las reglas
      // normales de edición (líder cualquier proyecto, apoyo solo el suyo asignado).
      allow update: if isActive() && (
        isAdmin() ||
        (tocaEstado()
          ? isValidTransition(resource.data.estado, request.resource.data.estado, myRol()) &&
            (myRol() == 'lider' || isAsignado())
          : (isLider() || isAsignado()))
      );

      // Solo admin puede eliminar
      allow delete: if isAdmin();
    }

    // ── Usuarios ──────────────────────────────────────────────────────────────
    match /users/{userId} {
      // Cualquier usuario activo puede leer perfiles (para selects de técnicos)
      allow read: if isActive();

      // Solo admin puede crear, modificar o eliminar usuarios
      allow write: if isAdmin();

      // Excepción: el propio usuario puede actualizar su perfil (cambio de contraseña UI)
      // pero NO puede cambiar su rol ni activo
      allow update: if isActive() && userId == uid() &&
        !request.resource.data.diff(resource.data).affectedKeys()
          .hasAny(['rol', 'activo', 'id']);
    }

    // ── KV store (inventario, presets de panel, config ligera) ───────────────
    match /kv/{key} {
      allow read: if isActive();
      allow write: if isLider() && isActive(); // admin y líderes escriben KV
    }

    // ── Configuración global ──────────────────────────────────────────────────
    match /config/{key} {
      allow read: if isActive();
      allow write: if isAdmin();
    }

    // ── Tarjetas públicas (QR del cliente) ───────────────────────────────────
    // Única colección legible SIN sesión — solo guarda el subconjunto de datos
    // ya pensado para mostrarse al cliente final (sin seriales/notas/fotos
    // internas). Se escribe desde la app (qr.js) cada vez que un técnico abre
    // la vista de QR del proyecto.
    match /publicCards/{id} {
      allow read: if true;
      allow write: if isActive();
    }

    // ── Recordatorios globales ────────────────────────────────────────────────
    match /reminders/{id} {
      allow read, write: if isActive();
    }

    // ── Errores de runtime ────────────────────────────────────────────────────
    // write-only para la app; solo admin puede leer
    match /errors/{id} {
      allow create: if isActive();
      allow read:   if isAdmin();
    }

    // ── Denegar todo lo demás por defecto ─────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
